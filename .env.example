# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_ME_AWS_SECRET_ACCESS_KEY

# AWS EKS / Terraform
TF_VAR_cluster_name=wordpress
TF_VAR_cluster_version=1.31
TF_VAR_node_desired_size=2
TF_VAR_node_min_size=1
TF_VAR_node_max_size=3
TF_VAR_node_instance_types=["t3.micro"]
TF_VAR_subnet_ids=["subnet-xxxxx","subnet-xxxxx","subnet-xxxxx"]

# Docker Registry
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=REPLACE_ME_DOCKER_PASSWORD
DOCKER_REPOSITORY=your_username/wordpress-custom
DOCKER_IMAGE_TAG=latest

# MySQL Secrets (change these!)
MYSQL_ROOT_PASSWORD=REPLACE_ME_MYSQL_ROOT_PASSWORD
MYSQL_PASSWORD=REPLACE_ME_MYSQL_PASSWORD
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser

# Optional ingress settings (used by Helm/workflows)
INGRESS_HOST=wordpress.example.com
INGRESS_TLS_SECRET_NAME=wordpress-tls
INGRESS_MANAGED_CERT_NAME=wordpress-managed-cert

# Kubernetes
KUBE_CONFIG_DATA=REPLACE_ME_BASE64_KUBECONFIG

# WordPress Configuration
WORDPRESS_DB_HOST=mysql:3306
WORDPRESS_DB_USER=${MYSQL_USER}
WORDPRESS_DB_NAME=${MYSQL_DATABASE}
